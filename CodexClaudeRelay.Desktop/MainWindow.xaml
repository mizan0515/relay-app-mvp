<Window x:Class="CodexClaudeRelay.Desktop.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Relay App MVP"
        Height="760"
        Width="1180"
        MinHeight="680"
        MinWidth="860"
        ResizeMode="CanResizeWithGrip">
    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  HorizontalScrollBarVisibility="Disabled"
                  CanContentScroll="True">
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0"
                Padding="12"
                CornerRadius="8"
                Background="#FFF4F6F8"
                BorderBrush="#FFD0D7DE"
                BorderThickness="1">
            <StackPanel>
                <TextBlock FontSize="22"
                           FontWeight="SemiBold"
                           Text="Relay App MVP" />
                <TextBlock Margin="0,6,0,0"
                           Foreground="#FF475467"
                           Text="One-session broker with strict handoff JSON parsing and automatic repair." />
            </StackPanel>
        </Border>

        <Grid Grid.Row="1" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*" />
                <ColumnDefinition Width="3*" />
            </Grid.ColumnDefinitions>

            <StackPanel Grid.Column="0" Margin="0,0,16,0">
                <TextBlock FontWeight="SemiBold" Text="Session Id" />
                <TextBox x:Name="SessionIdTextBox"
                         Margin="0,6,0,12"
                         Padding="8" />

                <TextBlock FontWeight="SemiBold" Text="Initial Prompt" />
                <TextBox x:Name="InitialPromptTextBox"
                         Margin="0,6,0,0"
                         Padding="8"
                         Height="100"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto" />

                <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Working Directory" />
                <TextBox x:Name="WorkingDirectoryTextBox"
                         Margin="0,6,0,0"
                         Padding="8" />

                <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Managed CardGame Root" />
                <TextBox x:Name="ManagedCardGameRootTextBox"
                         Margin="0,6,0,0"
                         Padding="8"
                         Text="D:\Unity\card game" />

                <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Managed Task Slug" />
                <TextBox x:Name="ManagedTaskSlugTextBox"
                         Margin="0,6,0,0"
                         Padding="8"
                         Text="companion-depth-first-slice" />

                <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Managed Turns" />
                <TextBox x:Name="ManagedTurnsTextBox"
                         Margin="0,6,0,0"
                         Padding="8"
                         Text="2" />

                <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Managed Loop Sessions" />
                <TextBox x:Name="ManagedLoopSessionsTextBox"
                         Margin="0,6,0,0"
                         Padding="8"
                         Text="3" />

                <CheckBox x:Name="UseInteractiveAdaptersCheckBox"
                          Margin="0,12,0,0"
                          Content="Use interactive adapters (experimental; Codex uses app-server, Claude uses stream-json)" />
                <CheckBox x:Name="AutoApproveAllRequestsCheckBox"
                          Margin="0,8,0,0"
                          Content="Dangerous: auto-approve all requests and only log them" />

                <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Adapter Status" />
                <Border x:Name="AdapterStatusBorder"
                        Margin="0,6,0,0"
                        Padding="12"
                        Background="#FFF8FAFC"
                        BorderBrush="#FFD0D7DE"
                        BorderThickness="1"
                        CornerRadius="8">
                    <TextBox x:Name="AdapterStatusTextBlock"
                             IsReadOnly="True"
                             IsReadOnlyCaretVisible="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0"
                             Height="96"
                             FontFamily="Consolas"
                             AcceptsReturn="True"
                             Text="Status not checked yet."
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto" />
                </Border>

                <TextBlock Margin="0,12,0,0" FontWeight="SemiBold" Text="Smoke Test Report" />
                <Border x:Name="SmokeTestReportBorder"
                        Margin="0,6,0,0"
                        Padding="12"
                        Background="#FFF8FAFC"
                        BorderBrush="#FFD0D7DE"
                        BorderThickness="1"
                        CornerRadius="8">
                    <TextBox x:Name="SmokeTestReportTextBlock"
                             IsReadOnly="True"
                             IsReadOnlyCaretVisible="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0"
                             Height="180"
                             FontFamily="Consolas"
                             AcceptsReturn="True"
                             Text="No smoke test has run yet."
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto" />
                </Border>
            </StackPanel>

            <StackPanel Grid.Column="1">
                <DockPanel LastChildFill="False">
                    <TextBlock FontWeight="SemiBold"
                               Text="Current Session State" />
                    <Border x:Name="SessionRiskBadgeBorder"
                            Margin="12,0,0,0"
                            Padding="8,2"
                            CornerRadius="999"
                            Background="#FFF8FAFC"
                            BorderBrush="#FFD0D7DE"
                            BorderThickness="1"
                            DockPanel.Dock="Right">
                        <TextBlock x:Name="SessionRiskBadgeTextBlock"
                                   FontWeight="SemiBold"
                                   Foreground="#FF344054"
                                   Text="Risk: none" />
                    </Border>
                </DockPanel>
                <Border x:Name="StateSummaryBorder"
                        Margin="0,6,0,0"
                        Padding="12"
                        Background="#FF101828"
                        BorderBrush="#FF101828"
                        BorderThickness="1"
                        CornerRadius="8">
                    <TextBox x:Name="StateSummaryTextBlock"
                             IsReadOnly="True"
                             IsReadOnlyCaretVisible="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0"
                             Height="180"
                             FontFamily="Consolas"
                             Foreground="#FFF8FAFC"
                             CaretBrush="#FFF8FAFC"
                             AcceptsReturn="True"
                             Text="No session loaded yet."
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto" />
                </Border>

                <TextBlock Margin="0,12,0,0"
                           FontWeight="SemiBold"
                           Text="Managed Autopilot Status" />
                <Border x:Name="ManagedStatusBorder"
                        Margin="0,6,0,0"
                        Padding="12"
                        Background="#FFF8FAFC"
                        BorderBrush="#FFD0D7DE"
                        BorderThickness="1"
                        CornerRadius="8">
                    <TextBox x:Name="ManagedStatusTextBox"
                             IsReadOnly="True"
                             IsReadOnlyCaretVisible="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0"
                             Height="120"
                             FontFamily="Consolas"
                             AcceptsReturn="True"
                             Text="Managed status not loaded yet."
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto" />
                </Border>

                <TextBlock Margin="0,12,0,0"
                           FontWeight="SemiBold"
                           Text="Easy Operator" />
                <Border x:Name="EasyOperatorBorder"
                        Margin="0,6,0,0"
                        Padding="12"
                        Background="#FFFDF3E8"
                        BorderBrush="#FFF7B27A"
                        BorderThickness="1"
                        CornerRadius="8">
                    <StackPanel>
                        <TextBlock FontWeight="SemiBold"
                                   Text="For a non-developer operator:" />
                        <TextBlock Margin="0,6,0,0"
                                   Text="1. Click Easy Start." />
                        <TextBlock Margin="0,2,0,0"
                                   Text="2. Wait until the app says attention is needed." />
                        <TextBlock Margin="0,2,0,0"
                                   Text="3. Read only Easy Status. Ignore full logs." />
                        <Button x:Name="EasyStartButton"
                                Width="180"
                                Height="38"
                                Margin="0,12,0,0"
                                HorizontalAlignment="Left"
                                Click="EasyStartButton_Click"
                                Content="Easy Start" />
                        <TextBox x:Name="EasyStatusTextBox"
                                 Margin="0,12,0,0"
                                 IsReadOnly="True"
                                 IsReadOnlyCaretVisible="True"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 Padding="0"
                                 Height="86"
                                 FontFamily="Consolas"
                                 AcceptsReturn="True"
                                 Text="Easy status not loaded yet."
                                 TextWrapping="Wrap"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto" />
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <StackPanel Grid.Row="2"
                    Margin="0,16,0,16">
            <WrapPanel Orientation="Horizontal"
                       ItemHeight="34">
                <Button x:Name="StartSessionButton"
                        Width="120"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="StartSessionButton_Click"
                        Content="Start Session" />
                <Button x:Name="CheckAdaptersButton"
                        Width="130"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="CheckAdaptersButton_Click"
                        Content="Check Adapters" />
                <Button x:Name="SmokeTestButton"
                        Width="130"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="SmokeTestButton_Click"
                        Content="Smoke Test 2" />
                <Button x:Name="AdvanceButton"
                        Width="120"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="AdvanceButton_Click"
                        Content="Advance Once" />
                <Button x:Name="RunCycleButton"
                        Width="130"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="RunCycleButton_Click"
                        Content="Run One Cycle" />
                <Button x:Name="RunManagedCardGameButton"
                        Width="180"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="RunManagedCardGameButton_Click"
                        Content="Managed CardGame Run" />
                <Button x:Name="RunManagedAutopilotButton"
                        Width="190"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="RunManagedAutopilotButton_Click"
                        Content="Managed Autopilot Run" />
                <Button x:Name="RunManagedNextStepButton"
                        Width="180"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="RunManagedNextStepButton_Click"
                        Content="Managed Next Step" />
                <Button x:Name="RunManagedUntilAttentionButton"
                        Width="220"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="RunManagedUntilAttentionButton_Click"
                        Content="Managed Run Until Attention" />
                <Button x:Name="RunManagedAutopilotLoopButton"
                        Width="200"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="RunManagedAutopilotLoopButton_Click"
                        Content="Managed Autopilot Loop" />
                <Button x:Name="RefreshManagedStatusButton"
                        Width="180"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="RefreshManagedStatusButton_Click"
                        Content="Refresh Managed Status" />
                <Button x:Name="AutoRunButton"
                        Width="120"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="AutoRunButton_Click"
                        Content="Auto Run 4" />
                <Button x:Name="PauseButton"
                        Width="100"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="PauseButton_Click"
                        Content="Pause" />
                <Button x:Name="StopButton"
                        Width="100"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="StopButton_Click"
                        Content="Stop" />
                <Button x:Name="OpenLogFolderButton"
                        Width="130"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="OpenLogFolderButton_Click"
                        Content="Open Log Folder" />
                <Button x:Name="ExportDiagnosticsButton"
                        Width="150"
                        Height="34"
                        Click="ExportDiagnosticsButton_Click"
                        Content="Export Diagnostics" />
                <Button x:Name="ApproveOnceButton"
                        Width="140"
                        Height="34"
                        Margin="8,0,8,0"
                        Click="ApproveOnceButton_Click"
                        Content="한 번만 허용"
                        ToolTip="이번 한 건만 허용합니다 (Approve Once)" />
                <Button x:Name="ApproveSessionButton"
                        Width="160"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="ApproveSessionButton_Click"
                        Content="세션 동안 허용"
                        ToolTip="이 세션이 끝날 때까지 같은 종류의 요청을 자동 허용 (Approve Session)" />
                <Button x:Name="DenyApprovalButton"
                        Width="100"
                        Height="34"
                        Margin="0,0,8,0"
                        Click="DenyApprovalButton_Click"
                        Content="거부"
                        ToolTip="이 요청을 거부합니다 (Deny)" />
                <Button x:Name="CancelApprovalButton"
                        Width="100"
                        Height="34"
                        Click="CancelApprovalButton_Click"
                        Content="취소"
                        ToolTip="승인 대기를 취소합니다 (Cancel)" />
                <Button x:Name="ClearSessionApprovalsButton"
                        Width="170"
                        Height="34"
                        Margin="8,0,0,0"
                        Click="ClearSessionApprovalsButton_Click"
                        Content="Clear Session Approvals" />
            </WrapPanel>

            <Border x:Name="BusyBorder"
                    Margin="0,10,0,0"
                    Padding="12"
                    Background="#EFF8FF"
                    BorderBrush="#B2DDFF"
                    BorderThickness="1"
                    CornerRadius="8"
                    Visibility="Collapsed">
                <StackPanel>
                    <TextBox x:Name="BusyMessageTextBlock"
                             IsReadOnly="True"
                             IsReadOnlyCaretVisible="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0"
                             FontWeight="SemiBold"
                             Text="Working..."
                             TextWrapping="Wrap" />
                    <ProgressBar x:Name="BusyProgressBar"
                                 Margin="0,8,0,0"
                                 Height="12"
                                 IsIndeterminate="True" />
                </StackPanel>
            </Border>
        </StackPanel>

        <Grid Grid.Row="3">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="3*" />
                <ColumnDefinition Width="2*" />
            </Grid.ColumnDefinitions>

            <Grid Grid.Column="0" Margin="0,0,16,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <TextBlock FontWeight="SemiBold" Text="Event Log Tail" />
                <TextBox x:Name="EventLogTextBox"
                         Grid.Row="1"
                         Margin="0,6,0,0"
                         Padding="8"
                         FontFamily="Consolas"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto" />
            </Grid>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="140" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="150" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="150" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="150" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="150" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="150" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="150" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="200" />
                </Grid.RowDefinitions>

                <TextBlock FontWeight="SemiBold" Text="Latest Accepted Handoff" />
                <TextBox x:Name="LatestHandoffTextBox"
                         Grid.Row="1"
                         Margin="0,6,0,16"
                         Padding="8"
                         FontFamily="Consolas"
                         IsReadOnlyCaretVisible="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto" />

                <TextBox Grid.Row="2"
                         x:Name="CurrentLogPathTextBlock"
                         Margin="0,0,0,8"
                         IsReadOnly="True"
                         BorderThickness="0"
                         Background="Transparent"
                         Padding="0"
                         Foreground="#FF475467"
                         Text="(no log file yet)"
                         TextWrapping="Wrap" />

                <TextBlock Grid.Row="3"
                           Margin="0,0,0,0"
                           FontWeight="SemiBold"
                           Text="Latest Approval" />
                <TextBox x:Name="LatestApprovalTextBox"
                         Grid.Row="4"
                         Margin="0,6,0,12"
                         Padding="8"
                         FontFamily="Consolas"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Text="No approval activity yet." />

                <Border x:Name="StatusMessageBorder"
                        Grid.Row="5"
                        Padding="12"
                        Background="#FFFFF7ED"
                        BorderBrush="#FFFDBA74"
                        BorderThickness="1"
                        CornerRadius="8">
                    <TextBox x:Name="StatusMessageTextBlock"
                             IsReadOnly="True"
                             IsReadOnlyCaretVisible="True"
                             BorderThickness="0"
                             Background="Transparent"
                             Padding="0"
                             MinHeight="48"
                             AcceptsReturn="True"
                             Text="Ready."
                             TextWrapping="Wrap"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto" />
                </Border>

                <TextBlock Grid.Row="6"
                           Margin="0,16,0,0"
                           FontWeight="SemiBold"
                           Text="Session Approval Rules" />
                <TextBox x:Name="SessionApprovalRulesTextBox"
                         Grid.Row="7"
                         Margin="0,6,0,12"
                         Padding="8"
                         FontFamily="Consolas"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Text="No saved session approval rules." />

                <TextBlock Grid.Row="8"
                           Margin="0,0,0,0"
                           FontWeight="SemiBold"
                           Text="Approval Queue" />
                <TextBox x:Name="ApprovalQueueTextBox"
                         Grid.Row="9"
                         Margin="0,6,0,12"
                         Padding="8"
                         FontFamily="Consolas"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Text="No approvals queued yet." />

                <TextBlock Grid.Row="10"
                           Margin="0,0,0,0"
                           FontWeight="SemiBold"
                           Text="Latest Tool Activity" />
                <TextBox x:Name="LatestToolActivityTextBox"
                         Grid.Row="11"
                         Margin="0,6,0,12"
                         Padding="8"
                         FontFamily="Consolas"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Text="No tool activity yet." />

                <TextBlock Grid.Row="12"
                           Margin="0,0,0,0"
                           FontWeight="SemiBold"
                           Text="Latest Git / PR Activity" />
                <TextBox x:Name="LatestGitActivityTextBox"
                         Grid.Row="13"
                         Margin="0,6,0,12"
                         Padding="8"
                         FontFamily="Consolas"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Text="No git or PR activity yet." />

                <TextBlock Grid.Row="14"
                           Margin="0,0,0,0"
                           FontWeight="SemiBold"
                           Text="Tool Category Summary" />
                <TextBox x:Name="ToolCategorySummaryTextBox"
                         Grid.Row="15"
                         Margin="0,6,0,12"
                         Padding="8"
                         FontFamily="Consolas"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Text="No categorized tool activity yet." />

                <TextBlock Grid.Row="16"
                           Margin="0,0,0,0"
                           FontWeight="SemiBold"
                           Text="Policy Gap Summary" />
                <TextBox x:Name="PolicyGapSummaryTextBox"
                         Grid.Row="17"
                         Margin="0,6,0,12"
                         Padding="8"
                         FontFamily="Consolas"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Text="No policy-gap advisories yet." />

                <TextBlock Grid.Row="18"
                           Margin="0,0,0,0"
                           FontWeight="SemiBold"
                           Text="Current Session Risk Summary" />
                <TextBox x:Name="CurrentSessionRiskSummaryTextBox"
                         Grid.Row="19"
                         Margin="0,6,0,12"
                         Padding="8"
                         FontFamily="Consolas"
                         IsReadOnly="True"
                         IsReadOnlyCaretVisible="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto"
                         Text="No elevated session risk indicators." />

                <TextBlock Grid.Row="20"
                           Margin="0,0,0,0"
                           FontWeight="SemiBold"
                           Text="Recent Events" />
                <TextBox x:Name="RecentEventsTextBox"
                         Grid.Row="21"
                         Margin="0,6,0,0"
                         Padding="8"
                         FontFamily="Consolas"
                         IsReadOnlyCaretVisible="True"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         VerticalScrollBarVisibility="Auto"
                         HorizontalScrollBarVisibility="Auto" />
            </Grid>
        </Grid>
    </Grid>
    </ScrollViewer>
</Window>
